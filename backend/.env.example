# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=true

# LLM API Configuration
# For local LLM (ollama, llama.cpp)
LLM_API=http://localhost:1234/v1/chat/completions

# For cloud-based LLM (uncomment and update as needed)
# LLM_API=https://api.openai.com/v1/chat/completions
# LLM_API_KEY=sk-your-key-here

# Optional: API timeout (seconds)
LLM_TIMEOUT=30

# Optional: Max tokens for responses
LLM_MAX_TOKENS=500
